{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://raw.githubusercontent.com/akua-dev/agentos/main/benchmarks/profiles/agentos/pi-action-trajectory.schema.json",
  "title": "Sanitized Pi action trajectory",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "harness", "events", "redactions"],
  "properties": {
    "schema_version": { "const": "0.1.0" },
    "harness": { "const": "pi" },
    "events": {
      "type": "array",
      "maxItems": 1000,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["timestamp", "actor", "event_type", "tool_name", "arguments_digest", "result_class", "duration_ms", "retry_of", "accepted_work_reference"],
        "properties": {
          "timestamp": {
            "anyOf": [
              { "$ref": "#/$defs/timestamp" },
              { "const": "unobserved" }
            ]
          },
          "actor": { "$ref": "#/$defs/nonEmptyText" },
          "event_type": { "enum": ["tool_call", "bash_execution"] },
          "tool_name": { "$ref": "#/$defs/nonEmptyText" },
          "arguments_digest": {
            "anyOf": [
              { "type": "string", "pattern": "^sha256:[a-f0-9]{64}$" },
              { "const": "unobserved" }
            ]
          },
          "result_class": { "enum": ["success", "error", "unobserved"] },
          "duration_ms": {
            "anyOf": [
              { "type": "number", "minimum": 0, "maximum": 8640000000000000 },
              { "const": "unobserved" }
            ]
          },
          "retry_of": {
            "description": "One-based event position of the latest equivalent failed action, null when no retry was observed, or unobserved when arguments prevent comparison.",
            "anyOf": [
              { "type": "integer", "minimum": 1 },
              { "type": "null" },
              { "const": "unobserved" }
            ]
          },
          "accepted_work_reference": { "$ref": "#/$defs/nonEmptyText" }
        }
      }
    },
    "redactions": {
      "type": "array",
      "maxItems": 13,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["kind", "count", "method"],
        "properties": {
          "kind": { "$ref": "#/$defs/nonEmptyText" },
          "count": { "type": "integer", "minimum": 1, "maximum": 10000000 },
          "method": { "$ref": "#/$defs/nonEmptyText" }
        }
      }
    }
  },
  "$defs": {
    "timestamp": {
      "type": "string",
      "maxLength": 32,
      "pattern": "^[0-9]{4}-[0-9]{2}-[0-9]{2}T[0-9]{2}:[0-9]{2}:[0-9]{2}(?:\\.[0-9]+)?Z$"
    },
    "nonEmptyText": {
      "type": "string",
      "minLength": 1,
      "maxLength": 256,
      "pattern": "\\S"
    }
  }
}
