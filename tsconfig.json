{
  "compilerOptions": {
    "lib": ["ESNext"],
    "target": "ESNext",
    "module": "Preserve",
    "moduleDetection": "force",
    "types": ["bun"],
    "moduleResolution": "bundler",
    "allowImportingTsExtensions": true,
    "verbatimModuleSyntax": true,
    "noEmit": true,
    "strict": true,
    "skipLibCheck": true,
    "noFallthroughCasesInSwitch": true,
    "noUncheckedIndexedAccess": true,
    "noImplicitOverride": true
  },
  "include": [
    "*.ts",
    "agents/**/*.ts",
    "agents/.pi/**/*.ts",
    "benchmarks/**/*.ts",
    "clis/**/*.ts",
    "database/**/*.ts",
    "release/**/*.ts",
    "runtime/**/*.ts",
    "services/**/*.ts"
  ]
}
